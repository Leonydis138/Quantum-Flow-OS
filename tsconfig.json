{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@quantum/*": ["src/*"],
      "@core/*": ["src/core/*"],
      "@governance/*": ["src/governance/*"],
      "@agents/*": ["src/agents/*"],
      "@security/*": ["src/security/*"],
      "@types/*": ["src/types/*"],
      "@utils/*": ["src/utils/*"],
      "@server/*": ["src/server/*"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
