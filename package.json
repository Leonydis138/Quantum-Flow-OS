{
  "name": "@quantum-flow/core",
  "version": "2.0.0",
  "description": "Quantum Flow OS v2 - Enterprise AI Safety & Governance Framework with Real-time Multi-Agent Orchestration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": "./dist/core/index.js",
    "./governance": "./dist/governance/index.js",
    "./agents": "./dist/agents/index.js",
    "./security": "./dist/security/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check && npm run test",
    "server": "node dist/server/index.js",
    "server:dev": "tsx watch src/server/index.ts",
    "cli": "node dist/cli/index.js",
    "generate:docs": "typedoc --out docs/api src"
  },
  "keywords": [
    "ai-safety",
    "ethical-ai",
    "governance",
    "compliance",
    "multi-agent",
    "real-time-orchestration",
    "semantic-routing",
    "capability-binding",
    "temporal-reasoning",
    "typescript"
  ],
  "author": "Leonydis138",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Leonydis138/Quantum-Flow-OS.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "zod": "^3.22.0",
    "uuid": "^9.0.1",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.1",
    "eventemitter3": "^5.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "tsx": "^4.7.0"
  }
}
